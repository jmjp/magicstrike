# JWT Configuration
JWT_SECRET=magicstrike_super_secret_key_change_me

# PostgreSQL (Auth & Sessions)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=magicstrike
POSTGRES_SSLMODE=disable

# ClickHouse (Event Data)
CLICKHOUSE_ADDR=127.0.0.1:9000
CLICKHOUSE_DB=magicstrike
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=test

# Qdrant (Vector DB for narratives)
QDRANT_URL=http://127.0.0.1:6333

# MinIO (S3 compatible object storage)
MINIO_ENDPOINT=http://127.0.0.1:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=magicstrike-demos

# RabbitMQ (Message Broker)
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
RABBITMQ_EXCHANGE=demo_uploads
RABBITMQ_QUEUE=demo_processing
RABBITMQ_ROUTING_KEY=demo.upload

# AI Services (Optional - Falls back to mock values if empty)
DEEPSEEK_API_KEY=
VOYAGE_API_KEY=
